# 데이터베이스 연결 주소 (예: postgresql://ID:PW@HOST:PORT/DBNAME)
DATABASE_URL="your_database_url_here"
# Redis 서버 주소 (예: redis://localhost:6379)
REDIS_URL="your_redis_url_here"
# Docker 환경에서 사용할 구글 API 키
GOOGLE_API_KEY_FOR_DOCKER="your_google_api_key_here"
# 사용할 구글 임베딩 모델명 (예: models/embedding-001)
GOOGLE_EMBEDDINGS_MODEL="your_google_embeddings_model_name"
# 기본 구글 AI 서비스 API 키 (Gemini 등)
GOOGLE_API_KEY="your_google_api_key_here"
# 보안 및 토큰 서명용 비밀키 (임의의 긴 문자열)
SECRET_KEY="your_random_secret_key_here"
# 토큰 암호화 알고리즘 (예: HS256)
ALGORITHM="HS256"
